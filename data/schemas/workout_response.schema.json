{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/schemas/workout_response.schema.json",
  "title": "Evidence-constrained workout generation response",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "safety", "programme", "citations", "uncertainties"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "status": {"enum": ["ok", "blocked_red_flag", "needs_clinician_input", "invalid_request"]},
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["red_flag_gate_passed", "side_specific_content_enabled", "warnings"],
      "properties": {
        "red_flag_gate_passed": {"type": "boolean"},
        "side_specific_content_enabled": {"type": "boolean"},
        "warnings": {"type": "array", "items": {"type": "string", "maxLength": 500}}
      }
    },
    "programme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weeks", "sessions"],
      "properties": {
        "weeks": {"type": "integer", "minimum": 1, "maximum": 24},
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["session_id", "title", "duration_min", "exercises"],
            "properties": {
              "session_id": {"type": "string"},
              "title": {"type": "string"},
              "duration_min": {"type": "integer", "minimum": 10, "maximum": 120},
              "exercises": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["exercise_id", "sets", "rep_target", "rir_target", "evidence_ids"],
                  "properties": {
                    "exercise_id": {"type": "string"},
                    "sets": {"type": "integer", "minimum": 1, "maximum": 6},
                    "rep_target": {"type": "string", "maxLength": 100},
                    "rir_target": {"type": ["number", "null"], "minimum": 0, "maximum": 6},
                    "tempo": {"type": ["string", "null"], "maxLength": 30},
                    "rest_seconds": {"type": ["integer", "null"], "minimum": 15, "maximum": 600},
                    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
                    "notes": {"type": "string", "maxLength": 800}
                  }
                }
              }
            }
          }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "claim"],
        "properties": {
          "evidence_id": {"type": "string"},
          "claim": {"type": "string", "maxLength": 500}
        }
      }
    },
    "uncertainties": {"type": "array", "items": {"type": "string", "maxLength": 500}},
    "weekly_adjustment_rules": {"type": "array", "items": {"type": "string", "maxLength": 500}}
  }
}
