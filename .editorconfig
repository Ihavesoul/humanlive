# Root editor + code-style config. Drives IntelliJ/Android Studio formatting
# and ktlint (run via CI; locally: `ktlint -F '**/*.kt'`).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.{kt,kts}]
# ktlint — https://pinterest.github.io/ktlint/latest/rules/code-configuration/
ktlint_standard_filename = enabled
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_function-naming = enabled
ktlint_standard_package-name = enabled
ij_kotlin_imports_layout = *
ij_kotlin_name_count_to_use_star_import = 99
ij_kotlin_name_count_to_use_star_import_for_members = 99

[*.{yml,yaml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
